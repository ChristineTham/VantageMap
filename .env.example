# ─────────────────────────────────────────────────────────────────────────────
# VantageMap — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local or any file containing real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Neon PostgreSQL - https://neon.tech) ───────────────────────────
# Connection string from the Neon console (includes sslmode=require)
# For app queries (HTTP driver): use the standard endpoint
DATABASE_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# For migrations/drizzle-kit (direct connection, no pooler):
#   Use the same DATABASE_URL above (HTTP driver doesn't need pooler)
#   If using WebSocket/TCP driver instead, use direct connection (without -pooler)
#
# For high-concurrency TCP connections (not needed for HTTP driver):
#   Add -pooler to the endpoint hostname:
#   postgresql://user:password@ep-example-123456-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Authentication (Better Auth) ─────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-at-least-32-char-random-string"
# Public URL of the application (used for callback URLs)
BETTER_AUTH_URL="http://localhost:3000"

# ── App (optional) ───────────────────────────────────────────────────────────
# Exposed to the browser; must start with NEXT_PUBLIC_
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── CI / Build ────────────────────────────────────────────────────────────────
# Set to "true" in CI to skip env validation during build (no real DB needed)
# SKIP_ENV_VALIDATION=true
